{
  "name": "ArnisRobloxStreaming",
  "servePort": 34874,
  "globIgnorePaths": [
    "src/ServerScriptService/StudioPreview/AustinPreviewManifestChunks/**",
    "src/ServerScriptService/StudioPreview/AustinPreviewManifestIndex.lua",
    "src/ServerStorage/SampleData/AustinHarnessManifestChunks/**",
    "src/ServerStorage/SampleData/AustinHarnessManifestIndex.lua",
    "src/ServerStorage/SampleData/AustinManifestChunks/**",
    "src/ServerStorage/SampleData/AustinManifestIndex.lua"
  ],
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$path": "src/ReplicatedStorage"
    },
    "ServerScriptService": {
      "$path": "src/ServerScriptService"
    },
    "ServerStorage": {
      "$className": "ServerStorage"
    },
    "HttpService": {
      "$className": "HttpService",
      "$properties": {
        "HttpEnabled": true
      }
    },
    "Lighting": {
      "$className": "Lighting",
      "$path": "src/Lighting",
      "$properties": {
        "Technology": "Future",
        "GlobalShadows": true,
        "Brightness": 2,
        "EnvironmentDiffuseScale": 1,
        "EnvironmentSpecularScale": 1,
        "ShadowSoftness": 0.2
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "StreamingEnabled": false
      },
      "$path": "src/Workspace"
    }
  }
}
